generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==========================================
// AUTH & MULTI-TENANT (Better Auth + Workspace)
// ==========================================

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  
  // Workspace relations
  workspaces    WorkspaceMember[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id            String    @id @default(cuid())
  userId        String
  accountId     String
  providerId    String
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  companies Company[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(VIEWER) // Owner, Admin, Editor, Viewer
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ==========================================
// COMPANY DOMAIN
// ==========================================

model Company {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  legalName   String?
  industry    String?
  description String?  @db.Text
  email       String?
  phone       String?
  address     String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // 1-to-1 Relations
  profile     CompanyProfile?
  brandKit    BrandKit?
  
  // 1-to-Many Relations
  clients     Client[]
  projects    Project[]
  products    Product[]
  services    Service[]
  documents   Document[]
  assets      Asset[]
  aiMemories  AIMemory[]
  activities  ActivityLog[]
  aiUsageLogs AIUsageLog[]
}

model CompanyProfile {
  id             String   @id @default(cuid())
  companyId      String   @unique
  history        String?  @db.Text
  vision         String?  @db.Text
  mission        String?  @db.Text
  values         String?  @db.Text
  certifications String?  @db.Text
  awards         String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BrandKit {
  id             String   @id @default(cuid())
  companyId      String   @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  font           String?
  header         String?  @db.Text
  footer         String?  @db.Text
  signatureUrl   String?
  stampUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Project {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  description String?   @db.Text
  category    String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ==========================================
// DOCUMENT & ASSETS DOMAIN
// ==========================================

model Template {
  id          String   @id @default(cuid())
  name        String
  category    String
  previewUrl  String?
  configUrl   String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   Document[]
}

model Document {
  id          String   @id @default(cuid())
  companyId   String
  templateId  String?
  title       String
  type        String   // Company Profile, SPH, Proposal, Invoice, dll.
  status      String   @default("Draft") // Draft, Review, Approved, Completed
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template    Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  versions    DocumentVersion[]
  exports     ExportHistory[]
  comments    Comment[]
  approvals   Approval[]
  signatures  Signature[]
  auditTrails AuditTrail[]
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  content    String   @db.Text
  createdBy  String
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ExportHistory {
  id         String   @id @default(cuid())
  documentId String
  format     String   // PDF, DOCX, PPTX, dll.
  fileUrl    String
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  message    String   @db.Text
  elementId  String?  // Position or specific element ID in the document
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Approval {
  id         String   @id @default(cuid())
  documentId String
  reviewerId String
  status     String   // Pending, Approved, Rejected, Revision
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Signature {
  id         String   @id @default(cuid())
  documentId String
  clientId   String?
  name       String
  email      String
  signature  String   @db.Text // Base64 image or signature data
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AuditTrail {
  id         String   @id @default(cuid())
  documentId String
  action     String   // e.g., "VIEWED_BY_CLIENT", "SIGNED_BY_CLIENT"
  actor      String?  // Client name or email
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Asset {
  id        String   @id @default(cuid())
  companyId String
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ==========================================
// SYSTEM & AI DOMAIN
// ==========================================

model AIMemory {
  id        String                 @id @default(cuid())
  companyId String
  content   String                 @db.Text
  embedding Unsupported("vector(768)")?
  metadata  String?                @db.Text // Stored as JSON string
  createdAt DateTime               @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String
  timestamp DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AIUsageLog {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  requestType String   // text-generation, vision-analysis, layout-generation, etc.
  tokenCount  Int      @default(0)
  timestamp   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
